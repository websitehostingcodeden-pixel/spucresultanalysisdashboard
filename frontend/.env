# ARIS Frontend Environment Variables

# API Configuration
VITE_API_URL=http://127.0.0.1:8000/api

# Auth Configuration  
VITE_AUTH_TOKEN_KEY=aris_auth_token
VITE_REFRESH_TOKEN_KEY=aris_refresh_token
VITE_UPLOAD_ID_KEY=aris_upload_id

# UI Configuration
VITE_APP_NAME=ARIS
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_PRESENTATION_MODE=true
VITE_ENABLE_EXPORT=true
